# ATLAS — Environment Variables
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.

# Bureau of Labor Statistics API key (free)
# Register at: https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# Federal Reserve Economic Data API key (free)
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Bureau of Economic Analysis API key (free)
# Register at: https://apps.bea.gov/API/signup/
BEA_API_KEY=
