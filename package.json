{
  "name": "atlas",
  "version": "0.1.0",
  "description": "AI Transformation Labor & Automation Simulator — predictive economic model for AI labor displacement and policy analysis",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext ts,tsx",
    "type-check": "tsc --noEmit",
    "fetch-data": "tsx scripts/fetch-bls-data.ts",
    "fetch-bls": "tsx scripts/fetch-bls-data.ts",
    "fetch-bea": "tsx scripts/fetch-bea-data.ts",
    "fetch-fred": "tsx scripts/fetch-fred-data.ts",
    "fetch-all-data": "npm run fetch-bls && npm run fetch-bea && npm run fetch-fred",
    "generate-fallback-data": "tsx scripts/generate-fallback-data.ts",
    "check-csv-drift": "tsx scripts/csv-drift-check.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.60.0",
    "@types/lz-string": "^1.3.34",
    "@types/papaparse": "^5.5.2",
    "@types/topojson-client": "^3.1.5",
    "d3": "^7.9.0",
    "decimal.js": "^10.4.3",
    "framer-motion": "^11.11.0",
    "html-to-image": "^1.11.13",
    "lz-string": "^1.5.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3",
    "topojson-client": "^3.1.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.2.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.14.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
